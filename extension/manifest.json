{
  "manifest_version": 3,
  "name": "CoWatch",
  "version": "0.1.0",
  "description": "Sync video playback with friends on any site, plus video/voice chat.",
  "browser_specific_settings": {
    "gecko": {
      "id": "cowatch@yourdomain.dev",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["websiteActivity", "personalCommunications"]
      }
    }
  },
  "background": {
    "scripts": ["background/index.js"]
  },
  "permissions": ["storage", "tabs", "clipboardWrite"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["vendor/jitsi-external-api.js", "content/index.js"]
    },
    {
      "matches": ["http://localhost/join-page/*"],
      "js": ["landing-bridge/index.js"]
    }
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup/index.html"
  }
}
