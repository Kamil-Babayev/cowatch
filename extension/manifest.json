{
  "manifest_version": 3,
  "name": "CoWatch",
  "version": "0.1.0",
  "browser_specific_settings": {
    "gecko": { "id": "cowatch@yourdomain.dev" }
  },
  "background": {
    "scripts": ["background/index.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"]
    }
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:8080/*",
    "https://cowatch.app/*"
  ],
  "action": {
    "default_popup": "popup/index.html"
  }
}